int imagenActual = 0; 
bool actualizarPantalla = true;


// =========================================================================
// 3. LÓGICA PRINCIPAL (SETUP & LOOP)
// =========================================================================

void setup() {
  u8g2.begin();
  
  pinMode(PIN_BOTON_DER, INPUT_PULLUP);
  pinMode(PIN_BOTON_IZQ, INPUT_PULLUP);
}

void loop() {
  int estadoBotonDer = digitalRead(PIN_BOTON_DER);
  int estadoBotonIzq = digitalRead(PIN_BOTON_IZQ);

  if (estadoBotonDer == LOW) {
    imagenActual++;
    if (imagenActual >= TOTAL_IMAGENES) {
      imagenActual = 0; 
    }
    actualizarPantalla = true;
    delay(250); // Debounce
  }

  if (estadoBotonIzq == LOW) {
    imagenActual--;
    if (imagenActual < 0) {
      imagenActual = TOTAL_IMAGENES - 1; 
    }
    actualizarPantalla = true;
    delay(250); // Debounce
  }

if (actualizarPantalla) {
    u8g2.firstPage();
    do {
      // 1. Fondo blanco desplazado 1 píxel a la derecha para alinearse con la imagen
      u8g2.setDrawColor(1);
      u8g2.drawBox(1, 0, SCREEN_WIDTH - 1, SCREEN_HEIGHT); // Cambiado: empieza en 1 y el ancho es 127

      // 2. Dibujamos el XBMP en la misma posición (x = 1)
      u8g2.setDrawColor(0);
      u8g2.drawXBMP(1, 0, SCREEN_WIDTH - 1, SCREEN_HEIGHT, listaImagenes[imagenActual]);

    } while ( u8g2.nextPage() );

    actualizarPantalla = false; 
}
